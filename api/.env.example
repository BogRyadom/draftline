# Copy to `.env` and fill in. Never commit the real .env (it is gitignored).

# ── Supabase / auth ──────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Optional: derived from SUPABASE_URL when left blank.
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
FRONTEND_ORIGIN=http://localhost:3000

# ── Database (Supabase Postgres, asyncpg connection string) ──────────────
DATABASE_URL=

# ── LLM (classify + draft) — Groq, free tier ─────────────────────────────
GROQ_API_KEY=

# ── Embeddings (text-embedding-004) — Gemini, free tier ──────────────────
GEMINI_API_KEY=

# ── Gmail OAuth (Phase 1) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ── Encrypts OAuth refresh tokens at rest (Fernet key, Phase 1) ──────────
FERNET_KEY=
